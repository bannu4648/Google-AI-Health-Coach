# Gemini LLM — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash
# Minimum seconds between Gemini calls (default 2)
GEMINI_CALL_DELAY_SECONDS=2
# Retries on HTTP 429 / quota with exponential backoff (2s, 4s, 8s by default)
GEMINI_RATE_LIMIT_MAX_RETRIES=3
GEMINI_RATE_LIMIT_BACKOFF_SECONDS=2

# Tavily nutrition search (free tier: 1,000 searches/month)
TAVILY_API_KEY=replace-me
TAVILY_SEARCH_DEPTH=basic
ENABLE_NUTRITION_SEARCH=true

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=replace-me
WHATSAPP_VERIFY_TOKEN=replace-me
WHATSAPP_PHONE_NUMBER_ID=replace-me
WHATSAPP_API_VERSION=v25.0

# Timezone (default: Hong Kong)
USER_TIMEZONE=Asia/Hong_Kong
USER_TIMEZONE_LABEL=HKT

# SQLite database
HEALTH_COACH_DB_PATH=data/health_coach.sqlite3

# Scheduled WhatsApp summaries (optional)
ENABLE_SCHEDULER=false
MORNING_SUMMARY_TIME=08:00
EVENING_SUMMARY_TIME=21:30
SUMMARY_RECIPIENT_PHONE=replace-me
