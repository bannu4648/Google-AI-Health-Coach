# LLM provider — gemini (default) or mistral
LLM_PROVIDER=gemini
# Optional generic overrides (otherwise provider-specific vars below are used)
# LLM_API_KEY=replace-me
# LLM_MODEL=gemini-2.5-flash

# Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash
# Mistral — get a key at https://console.mistral.ai/ (pip install mistralai)
# MISTRAL_API_KEY=replace-me
# MISTRAL_MODEL=mistral-large-latest
# Rate limits — spacing disabled by default for paid Gemini; 429 retries still apply
LLM_CALL_DELAY_SECONDS=0
LLM_RATE_LIMIT_MAX_RETRIES=3
LLM_RATE_LIMIT_BACKOFF_SECONDS=2
GEMINI_CALL_DELAY_SECONDS=0
GEMINI_RATE_LIMIT_MAX_RETRIES=3
GEMINI_RATE_LIMIT_BACKOFF_SECONDS=2

# Tavily nutrition search (free tier: 1,000 searches/month)
TAVILY_API_KEY=replace-me
TAVILY_SEARCH_DEPTH=basic
ENABLE_NUTRITION_SEARCH=true

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=replace-me
WHATSAPP_VERIFY_TOKEN=replace-me
WHATSAPP_PHONE_NUMBER_ID=replace-me
WHATSAPP_API_VERSION=v25.0
# Pre-approved Meta template for scheduled summaries (register in Meta Business Manager)
WHATSAPP_COACH_TEMPLATE=daily_coach_summary
WHATSAPP_SESSION_KEEPER_TEMPLATE=hello_world

# Timezone (default: Hong Kong)
USER_TIMEZONE=Asia/Hong_Kong
USER_TIMEZONE_LABEL=HKT

# Optional profile overrides (used when Google Health profile/height is missing)
# USER_PROFILE_AGE=34
# USER_PROFILE_HEIGHT_CM=175
# USER_PROFILE_WEIGHT_KG=75
# USER_PROFILE_SEX=male
# USER_PROFILE_CACHE_SECONDS=3600

# Conversation memory (WhatsApp history injected into LLM prompts)
CONVERSATION_MAX_TURNS=8
CONVERSATION_COACHING_MAX_TURNS=16
CONVERSATION_MAX_REPLY_CHARS=600

# Public HTTPS URL for webhooks and mobile Google OAuth (your ngrok URL, no trailing slash)
# PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev

# SQLite database
HEALTH_COACH_DB_PATH=data/health_coach.sqlite3

# Scheduled WhatsApp summaries (optional)
ENABLE_SCHEDULER=false
MORNING_SUMMARY_TIME=08:00
EVENING_SUMMARY_TIME=21:30
SUMMARY_RECIPIENT_PHONE=replace-me
# Optional mid-day readiness nudge (HKT, e.g. 14:30). Leave empty to disable.
# READINESS_NUDGE_TIME=14:30
# Workout adherence nudge when plan exists but no exercise logged (HKT)
WORKOUT_NUDGE_TIME=18:00
# Weekly recap (day: mon-sun, time HKT)
WEEKLY_RECAP_DAY=sun
WEEKLY_RECAP_TIME=21:00
# Session keeper: template ping if no inbound message in N hours (0=off)
SESSION_KEEPER_HOURS=20

# Coaching focus persistence
COACHING_FOCUS_ENABLED=true

# LangGraph checkpoint DB for interrupt/resume flows
GRAPH_CHECKPOINT_PATH=data/coach_graph.sqlite3
